{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "timezone": "Etc/UTC",
  "schedule": [
    "before 5am on monday"
  ],
  "labels": [
    "dependencies"
  ],
  "packageRules": [
    {
      "description": "Group Kubernetes, controller-runtime, and cert-manager dependencies across all Go modules",
      "groupName": "kubernetes",
      "matchManagers": [
        "gomod"
      ],
      "matchPackagePrefixes": [
        "k8s.io/",
        "sigs.k8s.io/controller-runtime",
        "github.com/cert-manager/cert-manager"
      ],
      "matchFileNames": [
        "controller/go.mod",
        "controller/deploy/operator/go.mod",
        "e2e/test/go.mod"
      ],
      "automerge": false
    },
    {
      "description": "Group official GitHub Actions (actions/*)",
      "groupName": "github-actions-official",
      "matchManagers": [
        "github-actions"
      ],
      "matchPackagePrefixes": [
        "actions/"
      ]
    },
    {
      "description": "Group Docker GitHub Actions (docker/*)",
      "groupName": "github-actions-docker",
      "matchManagers": [
        "github-actions"
      ],
      "matchPackagePrefixes": [
        "docker/"
      ]
    },
    {
      "description": "Group Astral GitHub Actions (astral-sh/*)",
      "groupName": "github-actions-astral",
      "matchManagers": [
        "github-actions"
      ],
      "matchPackagePrefixes": [
        "astral-sh/"
      ]
    },
    {
      "description": "Group grpcio, grpcio-tools, and protobuf Python packages for protocol compatibility",
      "groupName": "grpc-protobuf",
      "matchManagers": [
        "pep621"
      ],
      "matchPackageNames": [
        "grpcio",
        "grpcio-tools",
        "protobuf"
      ]
    },
    {
      "description": "Group kubernetes and kubernetes-asyncio Python packages to keep sync and async clients aligned",
      "groupName": "kubernetes-python",
      "matchManagers": [
        "pep621"
      ],
      "matchPackageNames": [
        "kubernetes",
        "kubernetes-asyncio"
      ]
    },
    {
      "description": "Group Go version directive updates across all Go modules",
      "groupName": "golang-version",
      "matchDepTypes": [
        "golang-version"
      ],
      "matchFileNames": [
        "controller/go.mod",
        "controller/deploy/operator/go.mod",
        "e2e/test/go.mod"
      ],
      "automerge": false
    },
    {
      "description": "Auto-merge patch updates for all dependencies",
      "matchUpdateTypes": [
        "patch"
      ],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Disable auto-merge for Docker base image updates",
      "matchManagers": [
        "dockerfile",
        "docker-compose"
      ],
      "automerge": false
    }
  ]
}

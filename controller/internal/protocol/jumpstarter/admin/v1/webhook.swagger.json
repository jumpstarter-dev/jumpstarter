    "v1EventClass": {
      "type": "string",
      "enum": [
        "EVENT_CLASS_UNSPECIFIED",
        "EVENT_CLASS_LEASE_CREATED",
        "EVENT_CLASS_LEASE_ENDED",
        "EVENT_CLASS_EXPORTER_OFFLINE",
        "EVENT_CLASS_EXPORTER_AVAILABLE",
        "EVENT_CLASS_CLIENT_CREATED",
        "EVENT_CLASS_CLIENT_DELETED"
      ],
      "default": "EVENT_CLASS_UNSPECIFIED",
      "description": "EventClass enumerates the webhook event categories a subscriber can\nregister interest in. Mirrored to/from the Webhook CRD's spec.events\nlist as strings."
    },
    "v1ResourceMetadata": {
      "type": "object",
      "properties": {
        "createdBy": {
          "type": "string",
          "description": "Display-only username of the OIDC caller that last mutated this\nresource (mirrored from the jumpstarter.dev/created-by annotation).\nOptional because resources created by GitOps / kubectl may not carry it.",
          "readOnly": true
        },
        "ownerIssuer": {
          "type": "string",
          "description": "OIDC issuer URL of the owner (jumpstarter.dev/owner-issuer annotation).",
          "readOnly": true
        },
        "resourceVersion": {
          "type": "string",
          "description": "Kubernetes resourceVersion. Used by clients for optimistic concurrency\nand by Watch* RPCs as a resume cursor.",
          "readOnly": true
        },
        "externallyManaged": {
          "type": "boolean",
          "description": "True when the resource is tracked by an external tool (ArgoCD,\nFlux, Helm, kustomize-controller, …). The controller refuses\nmutations on these via admin.v1 because edits would be reverted\non the next reconciliation; cluster admins can still kubectl-edit.\nDerived from labels/annotations on every read.",
          "readOnly": true
        }
      },
      "description": "ResourceMetadata bundles the identity-attribution and concurrency-control\nfields the controller stamps onto every Jumpstarter resource. Each domain\nresource embeds this as a field named \"metadata\" so admin clients see a\nuniform shape across resources."
    },

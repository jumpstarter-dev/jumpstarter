{
  "swagger": "2.0",
  "info": {
    "title": "jumpstarter/admin/v1/client.proto",
    "version": "version not set"
  },
  "tags": [
    {
      "name": "ClientService"
    }
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
    "/admin/v1/{client.name}": {
      "patch": {
        "operationId": "ClientService_UpdateClient",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1Client"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "client.name",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "namespaces/[^/]+/clients/[^/]+"
          },
          {
            "name": "client",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "username": {
                  "type": "string"
                },
                "labels": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                },
                "endpoint": {
                  "type": "string",
                  "description": "All three below are admin-surface only. Optional so a client.v1\nconsumer (or any caller through a path that doesn't populate them)\nsees them absent rather than as empty strings.",
                  "readOnly": true
                },
                "token": {
                  "type": "string",
                  "description": "token is populated only on CreateClient responses (the bootstrap\ncredential the controller mints inline) and is never echoed on\nGet/List/Update/Watch.",
                  "readOnly": true
                },
                "metadata": {
                  "$ref": "#/definitions/v1ResourceMetadata",
                  "readOnly": true
                },
                "type": {
                  "$ref": "#/definitions/v1ClientType",
                  "description": "type reflects the authentication mechanism this Client uses:\nOIDC for auto-provisioned identity Clients (bearer is the OIDC\ntoken directly), TOKEN for everything else (admin.v1-created bots,\nkubectl-applied, legacy). Derived on read from spec.username and\nthe jumpstarter.dev/owner annotation.",
                  "readOnly": true
                }
              },
              "description": "Client is the canonical Jumpstarter Client resource shape. The Client\nresource was previously not represented in client.v1 — it is added here\nfresh, so field numbering is unconstrained."
            }
          }
        ],
        "tags": [
          "ClientService"
        ]
      }
    },
    "/admin/v1/{name}": {
      "get": {
        "operationId": "ClientService_GetClient",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1Client"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "name",
            "description": "Resource name in the form \"namespaces/{namespace}/{plural}/{id}\",\ne.g. \"namespaces/lab-foo/leases/abcd1234\".",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "namespaces/[^/]+/clients/[^/]+"
          }
        ],
        "tags": [
          "ClientService"
        ]
      },
      "delete": {
        "operationId": "ClientService_DeleteClient",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "type": "object",
              "properties": {}
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "namespaces/[^/]+/clients/[^/]+"
          }
        ],
        "tags": [
          "ClientService"
        ]
      }
    },
    "/admin/v1/{parent}/clients": {
      "get": {
        "operationId": "ClientService_ListClients",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1ClientListResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "parent",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "namespaces/[^/]+"
          },
          {
            "name": "pageSize",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int32"
          },
          {
            "name": "pageToken",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "filter",
            "in": "query",
            "required": false,
            "type": "string"
          }
        ],
        "tags": [
          "ClientService"
        ]
      },
      "post": {
        "operationId": "ClientService_CreateClient",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1Client"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "parent",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "namespaces/[^/]+"
          },
          {
            "name": "client",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/v1Client"
            }
          },
          {
            "name": "clientId",
            "in": "query",
            "required": false,
            "type": "string"
          }
        ],
        "tags": [
          "ClientService"
        ]
      }
    },
    "/admin/v1/{parent}/clients:watch": {
      "get": {
        "operationId": "ClientService_WatchClients",
        "responses": {
          "200": {
            "description": "A successful response.(streaming responses)",
            "schema": {
              "type": "object",
              "properties": {
                "result": {
                  "$ref": "#/definitions/v1ClientEvent"
                },
                "error": {
                  "$ref": "#/definitions/rpcStatus"
                }
              },
              "title": "Stream result of v1ClientEvent"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "parent",
            "description": "Parent collection name, e.g. \"namespaces/lab-foo\".",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "namespaces/[^/]+"
          },
          {
            "name": "resourceVersion",
            "description": "Resume marker. Empty string starts from the current state; otherwise\nresumes after the given resourceVersion. The server returns\nOUT_OF_RANGE if the version is too old to resume from informer cache.",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "filter",
            "description": "Optional Kubernetes label selector applied server-side.",
            "in": "query",
            "required": false,
            "type": "string"
          }
        ],
        "tags": [
          "ClientService"
        ]
      }
    }
  },
  "definitions": {
    "protobufAny": {
      "type": "object",
      "properties": {
        "@type": {
          "type": "string"
        }
      },
      "additionalProperties": {}
    },
    "rpcStatus": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/protobufAny"
          }
        }
      }
    },
    "v1Client": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "username": {
          "type": "string"
        },
        "labels": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "endpoint": {
          "type": "string",
          "description": "All three below are admin-surface only. Optional so a client.v1\nconsumer (or any caller through a path that doesn't populate them)\nsees them absent rather than as empty strings.",
          "readOnly": true
        },
        "token": {
          "type": "string",
          "description": "token is populated only on CreateClient responses (the bootstrap\ncredential the controller mints inline) and is never echoed on\nGet/List/Update/Watch.",
          "readOnly": true
        },
        "metadata": {
          "$ref": "#/definitions/v1ResourceMetadata",
          "readOnly": true
        },
        "type": {
          "$ref": "#/definitions/v1ClientType",
          "description": "type reflects the authentication mechanism this Client uses:\nOIDC for auto-provisioned identity Clients (bearer is the OIDC\ntoken directly), TOKEN for everything else (admin.v1-created bots,\nkubectl-applied, legacy). Derived on read from spec.username and\nthe jumpstarter.dev/owner annotation.",
          "readOnly": true
        }
      },
      "description": "Client is the canonical Jumpstarter Client resource shape. The Client\nresource was previously not represented in client.v1 — it is added here\nfresh, so field numbering is unconstrained."
    },
    "v1ClientEvent": {
      "type": "object",
      "properties": {
        "eventType": {
          "$ref": "#/definitions/v1EventType"
        },
        "client": {
          "$ref": "#/definitions/v1Client"
        },
        "resourceVersion": {
          "type": "string"
        }
      }
    },
    "v1ClientListResponse": {
      "type": "object",
      "properties": {
        "clients": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v1Client"
          }
        },
        "nextPageToken": {
          "type": "string"
        }
      }
    },
    "v1ClientType": {
      "type": "string",
      "enum": [
        "CLIENT_TYPE_UNSPECIFIED",
        "CLIENT_TYPE_OIDC",
        "CLIENT_TYPE_TOKEN"
      ],
      "default": "CLIENT_TYPE_UNSPECIFIED",
      "description": "ClientType reflects how a Client authenticates to the controller.\n\nOIDC clients are auto-provisioned for the OIDC user (or SA principal)\non their first contact via client.v1; they use the OIDC bearer token\ndirectly to call into the controller, with no static credential.\n\nTOKEN clients hold a static bootstrap credential — admin.v1.CreateClient\nmints these inline; legacy and kubectl-applied Clients fall here too.\n\nDerived at conversion time from spec.username and the\njumpstarter.dev/owner annotation; never persisted to the CRD."
    },
    "v1EventType": {
      "type": "string",
      "enum": [
        "EVENT_TYPE_UNSPECIFIED",
        "EVENT_TYPE_ADDED",
        "EVENT_TYPE_MODIFIED",
        "EVENT_TYPE_DELETED",
        "EVENT_TYPE_BOOKMARK"
      ],
      "default": "EVENT_TYPE_UNSPECIFIED",
      "description": "EventType classifies a Watch* stream event. Mirrors Kubernetes\nwatch.Event semantics (ADDED, MODIFIED, DELETED, BOOKMARK).\n\n - EVENT_TYPE_BOOKMARK: BOOKMARK carries no resource payload, only a resource_version\ncheckpoint. Servers emit bookmarks every ~30s on otherwise idle\nstreams to keep HTTP connections alive across idle timeouts and\nto give clients a resumable cursor."
    },
    "v1ResourceMetadata": {
      "type": "object",
      "properties": {
        "createdBy": {
          "type": "string",
          "description": "Display-only username of the OIDC caller that last mutated this\nresource (mirrored from the jumpstarter.dev/created-by annotation).\nOptional because resources created by GitOps / kubectl may not carry it.",
          "readOnly": true
        },
        "ownerIssuer": {
          "type": "string",
          "description": "OIDC issuer URL of the owner (jumpstarter.dev/owner-issuer annotation).",
          "readOnly": true
        },
        "resourceVersion": {
          "type": "string",
          "description": "Kubernetes resourceVersion. Used by clients for optimistic concurrency\nand by Watch* RPCs as a resume cursor.",
          "readOnly": true
        },
        "externallyManaged": {
          "type": "boolean",
          "description": "True when the resource is tracked by an external tool (ArgoCD,\nFlux, Helm, kustomize-controller, …). The controller refuses\nmutations on these via admin.v1 because edits would be reverted\non the next reconciliation; cluster admins can still kubectl-edit.\nDerived from labels/annotations on every read.",
          "readOnly": true
        }
      },
      "description": "ResourceMetadata bundles the identity-attribution and concurrency-control\nfields the controller stamps onto every Jumpstarter resource. Each domain\nresource embeds this as a field named \"metadata\" so admin clients see a\nuniform shape across resources."
    }
  }
}

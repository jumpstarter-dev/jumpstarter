    "/admin/v1/{parent}/exporters:watch": {
      "get": {
        "operationId": "ExporterService_WatchExporters",
        "responses": {
          "200": {
            "description": "A successful response.(streaming responses)",
            "schema": {
              "type": "object",
              "properties": {
                "result": {
                  "$ref": "#/definitions/v1ExporterEvent"
                },
                "error": {
                  "$ref": "#/definitions/rpcStatus"
                }
              },
              "title": "Stream result of v1ExporterEvent"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "parent",
            "description": "Parent collection name, e.g. \"namespaces/lab-foo\".",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "namespaces/[^/]+"
          },
          {
            "name": "resourceVersion",
            "description": "Resume marker. Empty string starts from the current state; otherwise\nresumes after the given resourceVersion. The server returns\nOUT_OF_RANGE if the version is too old to resume from informer cache.",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "filter",
            "description": "Optional Kubernetes label selector applied server-side.",
            "in": "query",
            "required": false,
            "type": "string"
          }
        ],
        "tags": [
          "ExporterService"
        ]
      }
    }

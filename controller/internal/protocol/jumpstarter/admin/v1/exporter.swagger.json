        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "namespaces/[^/]+/exporters/[^/]+"
          }
        ],
        "tags": [
          "ExporterService"
        ]
      }

        },
        "parameters": [
          {
            "name": "name",
            "description": "Resource name in the form \"namespaces/{namespace}/{plural}/{id}\",\ne.g. \"namespaces/lab-foo/leases/abcd1234\".",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "namespaces/[^/]+/exporters/[^/]+"
          }
        ],
        "tags": [
          "ExporterService"
        ]
      },

  "paths": {
    "/admin/v1/{exporter.name}": {
      "patch": {
        "operationId": "ExporterService_UpdateExporter",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1Exporter"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "exporter.name",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "namespaces/[^/]+/exporters/[^/]+"
          },
          {
            "name": "exporter",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "labels": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                },
                "online": {
                  "type": "boolean",
                  "description": "Deprecated boolean liveness signal kept for client.v1 wire compatibility.\nUse status instead.",
                  "readOnly": true
                },
                "status": {
                  "$ref": "#/definitions/v1ExporterStatus",
                  "readOnly": true
                },
                "statusMessage": {
                  "type": "string",
                  "readOnly": true
                },
                "username": {
                  "type": "string",
                  "description": "Admin-surface extensions (\u003e= 6 so legacy client.v1 callers don't\ncollide with these new fields). All are optional because the legacy\nclient.v1 surface never populates them and admin Get/List/Watch may\nalso legitimately omit token after the bootstrap secret is rotated."
                },
                "endpoint": {
                  "type": "string",
                  "readOnly": true
                },
                "token": {
                  "type": "string",
                  "description": "token is populated only on CreateExporter responses (the bootstrap\ncredential the controller mints inline) and is never echoed on\nGet/List/Update/Watch.",
                  "readOnly": true
                },
                "metadata": {
                  "$ref": "#/definitions/v1ResourceMetadata",
                  "readOnly": true
                }
              },
              "description": "Exporter is the canonical Jumpstarter Exporter resource shape."
            }
          }
        ],
        "tags": [
          "ExporterService"
        ]
      }
    },

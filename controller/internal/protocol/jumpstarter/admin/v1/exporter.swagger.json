          }
        }
      }
    },
    "v1EventType": {
      "type": "string",
      "enum": [
        "EVENT_TYPE_UNSPECIFIED",
        "EVENT_TYPE_ADDED",
        "EVENT_TYPE_MODIFIED",
        "EVENT_TYPE_DELETED",
        "EVENT_TYPE_BOOKMARK"
      ],
      "default": "EVENT_TYPE_UNSPECIFIED",
      "description": "EventType classifies a Watch* stream event. Mirrors Kubernetes\nwatch.Event semantics (ADDED, MODIFIED, DELETED, BOOKMARK).\n\n - EVENT_TYPE_BOOKMARK: BOOKMARK carries no resource payload, only a resource_version\ncheckpoint. Servers emit bookmarks every ~30s on otherwise idle\nstreams to keep HTTP connections alive across idle timeouts and\nto give clients a resumable cursor."
    },
    "v1Exporter": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "labels": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "online": {
          "type": "boolean",
          "description": "Deprecated boolean liveness signal kept for client.v1 wire compatibility.\nUse status instead.",
          "readOnly": true
        },
        "status": {
          "$ref": "#/definitions/v1ExporterStatus",
          "readOnly": true
        },
        "statusMessage": {
          "type": "string",
          "readOnly": true
        },
        "username": {
          "type": "string",
          "description": "Admin-surface extensions (\u003e= 6 so legacy client.v1 callers don't\ncollide with these new fields). All are optional because the legacy\nclient.v1 surface never populates them and admin Get/List/Watch may\nalso legitimately omit token after the bootstrap secret is rotated."
        },
        "endpoint": {
          "type": "string",
          "readOnly": true
        },
        "token": {
          "type": "string",
          "description": "token is populated only on CreateExporter responses (the bootstrap\ncredential the controller mints inline) and is never echoed on\nGet/List/Update/Watch.",
          "readOnly": true
        },
        "metadata": {
          "$ref": "#/definitions/v1ResourceMetadata",
          "readOnly": true
        }
      },
      "description": "Exporter is the canonical Jumpstarter Exporter resource shape."
    },
    "v1ExporterEvent": {
      "type": "object",
      "properties": {
        "eventType": {
          "$ref": "#/definitions/v1EventType"
        },
        "exporter": {
          "$ref": "#/definitions/v1Exporter"
        },
        "resourceVersion": {
          "type": "string"
        }
      }
    },
    "v1ExporterListResponse": {
      "type": "object",
      "properties": {
        "exporters": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v1Exporter"
          }
        },
        "nextPageToken": {
          "type": "string"
        }
      }
    },
    "v1ExporterStatus": {
      "type": "string",
      "enum": [
        "EXPORTER_STATUS_UNSPECIFIED",
        "EXPORTER_STATUS_OFFLINE",
        "EXPORTER_STATUS_AVAILABLE",
        "EXPORTER_STATUS_BEFORE_LEASE_HOOK",
        "EXPORTER_STATUS_LEASE_READY",
        "EXPORTER_STATUS_AFTER_LEASE_HOOK",
        "EXPORTER_STATUS_BEFORE_LEASE_HOOK_FAILED",
        "EXPORTER_STATUS_AFTER_LEASE_HOOK_FAILED"
      ],
      "default": "EXPORTER_STATUS_UNSPECIFIED",
      "description": "- EXPORTER_STATUS_UNSPECIFIED: Unspecified exporter status\n - EXPORTER_STATUS_OFFLINE: Exporter is offline\n - EXPORTER_STATUS_AVAILABLE: Exporter is available to be leased\n - EXPORTER_STATUS_BEFORE_LEASE_HOOK: Exporter is executing before lease hook(s)\n - EXPORTER_STATUS_LEASE_READY: Exporter is leased and ready to accept commands\n - EXPORTER_STATUS_AFTER_LEASE_HOOK: Exporter is executing after lease hook(s)\n - EXPORTER_STATUS_BEFORE_LEASE_HOOK_FAILED: Exporter before lease hook failed\n - EXPORTER_STATUS_AFTER_LEASE_HOOK_FAILED: Exporter after lease hook failed",
      "title": "Exporter status information"
    },
    "v1ResourceMetadata": {
      "type": "object",
      "properties": {
        "createdBy": {
          "type": "string",
          "description": "Display-only username of the OIDC caller that last mutated this\nresource (mirrored from the jumpstarter.dev/created-by annotation).\nOptional because resources created by GitOps / kubectl may not carry it.",
          "readOnly": true
        },
        "ownerIssuer": {
          "type": "string",
          "description": "OIDC issuer URL of the owner (jumpstarter.dev/owner-issuer annotation).",
          "readOnly": true
        },
        "resourceVersion": {
          "type": "string",
          "description": "Kubernetes resourceVersion. Used by clients for optimistic concurrency\nand by Watch* RPCs as a resume cursor.",
          "readOnly": true
        }
      },
      "description": "ResourceMetadata bundles the identity-attribution and concurrency-control\nfields the controller stamps onto every Jumpstarter resource. Each domain\nresource embeds this as a field named \"metadata\" so admin clients see a\nuniform shape across resources."
    }

          },
          {
            "name": "lease",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "selector": {
                  "type": "string",
                  "description": "Either selector or exporter_name must be set. The combination is\nintentionally not enforced as REQUIRED here so the message can also\ncarry an empty selector when exporter_name is the chosen pin."
                },
                "duration": {
                  "type": "string"
                },
                "effectiveDuration": {
                  "type": "string",
                  "readOnly": true
                },
                "beginTime": {
                  "type": "string",
                  "format": "date-time"
                },
                "effectiveBeginTime": {
                  "type": "string",
                  "format": "date-time",
                  "readOnly": true
                },
                "endTime": {
                  "type": "string",
                  "format": "date-time"
                },
                "effectiveEndTime": {
                  "type": "string",
                  "format": "date-time",
                  "readOnly": true
                },
                "client": {
                  "type": "string",
                  "readOnly": true
                },
                "exporter": {
                  "type": "string",
                  "readOnly": true
                },
                "conditions": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "$ref": "#/definitions/v1Condition"
                  },
                  "readOnly": true
                },
                "exporterName": {
                  "type": "string"
                },
                "tags": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                },
                "ended": {
                  "type": "boolean",
                  "description": "Admin-surface extensions. Numbered \u003e= 14 so client.v1 wire format is\nunchanged for deployed jmp CLI binaries; older clients ignore them.",
                  "readOnly": true
                },
                "labels": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                },
                "metadata": {
                  "$ref": "#/definitions/v1ResourceMetadata",
                  "description": "metadata is populated only by the admin surface; client.v1 callers\nobserve an absent field, which is why it is optional.",
                  "readOnly": true
                }
              },
              "description": "Lease is the canonical Jumpstarter Lease resource shape. It mirrors the\nLease CRD (controller/api/v1alpha1/lease_types.go)."
            }
          }
        ],
        "tags": [
          "ClientService"
        ]
      }
    },
